runBM= function(outcome){
  #' Run BabyMonitor for a given outcome, results in a returner object
  #' Don't upload to Githuboutcome = 'survival'
  outcome_type = 'dichotomous'
  if (outcome=='gv'){
    outcome_type = 'cont'
  }

  dat = outcome_list[[outcome]]
  cat_vars = dat$cat_vars
  cont_vars = dat$cont_vars
  num_cat = length(cat_vars)
  num_cont = length(cont_vars);
  id_var = 'hospid'
  minimal_data = neonatal[ ,c(outcome, id_var, cat_vars, cont_vars)]

  #Fit baby monitor
  bm = babyMonitor(minimal_data, num_cat, num_cont, outcome_type = outcome_type, use_JAGS = TRUE)
  bm2 = babyMonitor(minimal_data, num_cat, num_cont, outcome_type = outcome_type)
  plot(bm$score_est, bm$dg_z)
  plot(bm$score_est, bm2$score_est)
  head(bm)


}